<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jianqing.module.system.mapper.SysNoticeTargetMapper">

    <delete id="deleteByNoticeId">
        DELETE FROM jq_sys_notice_target
        WHERE notice_id = #{noticeId}
    </delete>

    <insert id="batchInsert">
        INSERT INTO jq_sys_notice_target (notice_id, target_type, target_id)
        VALUES
        <foreach collection="targetIds" item="targetId" separator=",">
            (#{noticeId}, #{targetType}, #{targetId})
        </foreach>
    </insert>

    <select id="selectTargetIdsByNoticeId" resultType="java.lang.Long">
        SELECT target_id
        FROM jq_sys_notice_target
        WHERE notice_id = #{noticeId}
        ORDER BY id ASC
    </select>

</mapper>
